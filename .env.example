# Copy to .env.local and fill in. Restart the dev server after changes.

# Resend — sends the contact-form emails. Create a key at
# https://resend.com/api-keys and verify the lade.digital domain first
# (https://resend.com/domains: add the DNS records Resend gives you).
RESEND_API_KEY=

# Studio inbox that receives new enquiries. Defaults to info@lade.digital.
CONTACT_TO_EMAIL=info@lade.digital

# Verified sender on the lade.digital domain. Must use a domain you've
# verified in Resend. Defaults to "Lade Studio <hello@lade.digital>".
CONTACT_FROM_EMAIL=Lade Studio <hello@lade.digital>

# Absolute site origin, used in email footers and metadata.
NEXT_PUBLIC_SITE_URL=https://lade.digital
